{
  "name": "yii2-vscode-bridge",
  "displayName": "Yii2 VSCode Bridge",
  "description": "用于配合 PHP Intelephense，弥补其在 Yii2 框架中的动态语义识别不足，适用于 VSCode、Cursor 等基于 VSCode 扩展生态的编辑器。",
  "version": "0.0.2",
  "publisher": "local",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flyu518/yii2-vscode-bridge.git"
  },
  "homepage": "https://github.com/flyu518/yii2-vscode-bridge",
  "bugs": {
    "url": "https://github.com/flyu518/yii2-vscode-bridge/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:php",
    "onCommand:yii2Bridge.applyWorkspaceSettings",
    "onCommand:yii2Bridge.inspectSymbol",
    "workspaceContains:ide.php"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "yii2Bridge.applyWorkspaceSettings",
        "title": "Yii2 Bridge: Apply Workspace Settings"
      },
      {
        "command": "yii2Bridge.reindex",
        "title": "Yii2 Bridge: Reindex Project"
      },
      {
        "command": "yii2Bridge.inspectSymbol",
        "title": "Yii2 Bridge: Inspect Symbol"
      }
    ],
    "configuration": {
      "title": "Yii2 VSCode Bridge",
      "properties": {
        "yii2Bridge.ideStubFiles": {
          "type": "array",
          "default": [
            "ide.php",
            "config/__autocomplete.php"
          ],
          "items": {
            "type": "string"
          },
          "description": "Workspace-relative glob patterns used to find Yii IDE helper stub files."
        },
        "yii2Bridge.configFiles": {
          "type": "array",
          "default": [
            "common/config/*.php",
            "api/config/*.php",
            "console/config/*.php",
            "config/*.php"
          ],
          "items": {
            "type": "string"
          },
          "description": "Workspace-relative glob patterns used to find Yii config files."
        },
        "yii2Bridge.enableBuiltInComponents": {
          "type": "boolean",
          "default": true,
          "description": "Whether to seed common Yii application components when no explicit metadata exists."
        },
        "yii2Bridge.classFiles": {
          "type": "array",
          "default": [
            "api/**/*.php",
            "common/**/*.php",
            "console/**/*.php",
            "models/**/*.php",
            "controllers/**/*.php",
            "components/**/*.php",
            "services/**/*.php",
            "commands/**/*.php",
            "vendor/yiisoft/yii2/**/*.php"
          ],
          "items": {
            "type": "string"
          },
          "description": "Workspace-relative glob patterns used to find PHP class files for Yii-aware indexing."
        },
        "yii2Bridge.paramsFiles": {
          "type": "array",
          "default": [
            "common/config/params*.php",
            "api/config/params*.php",
            "console/config/params*.php",
            "config/params*.php"
          ],
          "items": {
            "type": "string"
          },
          "description": "Workspace-relative glob patterns used to find Yii params files."
        }
      }
    }
  },
  "scripts": {
    "check": "node ./src/test/parserSelfCheck.js"
  },
  "keywords": [
    "yii2",
    "php",
    "intelephense",
    "vscode"
  ],
  "devDependencies": {
    "@vscode/vsce": "^3.7.1"
  }
}
